{
  "name": "yieldpos-client",
  "version": "1.0.0",
  "description": "YieldPOS Client - Electron + SQLite + Supabase",
  "main": "main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=& electron . --register",
    "register": "set ELECTRON_RUN_AS_NODE=& electron . --register",
    "admin": "set ELECTRON_RUN_AS_NODE=& electron . --admin",
    "dev": "set ELECTRON_RUN_AS_NODE=& electron . --register --dev",
    "dev:admin": "set ELECTRON_RUN_AS_NODE=& electron . --admin --dev",
    "snapshot:db": "node snapshot-runtime-db.js",
    "audit:db": "node scripts/audit-bundled-db.js",
    "import": "node import-data.js",
    "build": "electron-builder --win && node scripts/copy-external-images.js && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-launchers.ps1",
    "build:portable": "electron-builder --win portable && node scripts/copy-external-images.js && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-launchers.ps1",
    "build:installer": "electron-builder --win nsis && node scripts/copy-external-images.js && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-launchers.ps1",
    "build:launchers": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-launchers.ps1",
    "package:flat": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-flat-package.ps1",
    "build:flat": "npm run build:portable && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-flat-package.ps1"
  },
  "dependencies": {
    "node-hid": "^3.1.0",
    "node-thermal-printer": "^4.6.0",
    "pg": "^8.20.0",
    "serialport": "^12.0.0",
    "sql.js": "^1.11.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "docx": "^9.6.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.yieldpos.client",
    "productName": "YieldPOS Client",
    "directories": {
      "output": "dist2"
    },
    "npmRebuild": false,
    "asarUnpack": [
      "rawprint.ps1",
      "opos-bridge.ps1",
      "scale_reader.py",
      "scanner-bridge.exe",
      "barcode-live.ps1",
      "install-kill-ptpos-task.ps1",
      "kill-ptpos.ps1"
    ],
    "files": [
      "main.js",
      "preload.js",
      "linkly.js",
      "lan-sync.js",
      "rawprint.ps1",
      "opos-bridge.ps1",
      "scale_reader.py",
      "scanner-bridge.exe",
      "barcode-live.ps1",
      "install-kill-ptpos-task.ps1",
      "kill-ptpos.ps1",
      "package.json",
      "products.json",
      "keyboard-layout.json",
      "scripts/apply-spoken-shop-prices.js",
      "pos/**",
      "!pos/images/**",
      "!pos/new sections/**",
      "db/**",
      "!db/crisp-pos.before-*.sqlite",
      "!**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "pos/YieldPOS.png"
    },
    "portable": {
      "artifactName": "YieldPOS-Client-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "artifactName": "YieldPOS-Client-Setup-${version}.exe"
    },
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ]
  },
  "author": "Matthias Campbell",
  "license": "MIT"
}
